# e-Boekhouden API token — create one under
# "Beheer → Instellingen → API/SOAP" in your e-Boekhouden administration.
# This is the secret token exchanged for a short-lived session token.
EBOEKHOUDEN_API_TOKEN=

# Optional label for the administration this token belongs to (free choice,
# used as the `administration` selector in tools, e.g. "demo" or the company
# name). When omitted, the token is registered under the label "default".
EBOEKHOUDEN_ADMINISTRATION=

# Integration identifier sent as the session `source` (max 10 chars, [A-Za-z0-9_ ]).
# Defaults to "codemill" when omitted.
EBOEKHOUDEN_SOURCE=codemill

# Optional explicit path to the multi-administration credentials JSON file.
# Default precedence: EBOEKHOUDEN_CREDENTIALS_FILE → ~/.e-boekhouden/credentials.json → ./credentials.json
EBOEKHOUDEN_CREDENTIALS_FILE=

# When set to "true", allows API calls that create, update or delete data in the administration.
EBOEKHOUDEN_ALLOW_WRITES=
